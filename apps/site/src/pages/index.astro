---
import { Picture } from "astro:assets";
import appScreenshot from "../assets/app-dashboard.png";
import BrandMark from "../components/BrandMark.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { product } from "../config";
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    question: "Which accounts does Limit Lifeboat support?",
    answer:
      "It supports Claude subscription accounts used by Claude Code and ChatGPT subscription accounts used by the Codex CLI. You can use either provider or both.",
  },
  {
    question: "What changes when I switch an account?",
    answer:
      "Only the selected provider’s CLI authentication fields change. Limit Lifeboat preserves unrelated CLI and MCP settings, validates the restored identity, and rolls back safely if verification fails.",
  },
  {
    question: "Does it switch my browser or desktop app too?",
    answer:
      "No. Browser, Claude Desktop, ChatGPT Desktop, and CLI sessions are separate. Limit Lifeboat switches the corresponding command-line tool only.",
  },
  {
    question: "Does the app update itself?",
    answer:
      "No. It checks GitHub once a day and links to a newer release when one is available. Installing an update always stays in your control.",
  },
  {
    question: "Where does my account data live?",
    answer:
      "Profiles and usage history stay in your user Library. App-managed credential snapshots are encrypted by macOS Keychain. There is no product analytics, advertising, or telemetry.",
  },
  {
    question: "Can I use an Intel Mac?",
    answer:
      `Not in version ${product.version}. Limit Lifeboat requires an Apple Silicon Mac running ${product.minimumMacOS} or newer.`,
  },
] as const;

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      name: product.name,
      url: product.siteUrl,
      description: product.shortDescription,
      applicationCategory: "UtilitiesApplication",
      operatingSystem: `${product.minimumMacOS} or newer`,
      softwareVersion: product.version,
      downloadUrl: product.links.latestRelease,
      codeRepository: product.links.repository,
      license: product.links.license,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "USD",
      },
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout structuredData={structuredData}>
  <section class="hero">
    <div class="hero-orb hero-orb--one" aria-hidden="true"></div>
    <div class="hero-orb hero-orb--two" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow hero-eyebrow">
          <span class="status-dot"></span>
          Native macOS menu-bar app
        </p>
        <h1>Keep every AI coding account <span>afloat.</span></h1>
        <p class="hero-lead">
          See Claude and ChatGPT/Codex usage at a glance. Get warned before a limit catches you,
          then switch the right CLI account without losing the rest of your setup.
        </p>
        <div class="hero-actions">
          <a class="button button--primary button--large" href={product.links.latestRelease}>
            <svg aria-hidden="true" viewBox="0 0 18 18" width="18" height="18">
              <path d="M9 2v9m0 0 3.5-3.5M9 11 5.5 7.5M3 15h12" />
            </svg>
            Download for Mac
          </a>
          <a class="button button--secondary button--large" href={product.links.repository}>
            View on GitHub
            <svg aria-hidden="true" viewBox="0 0 18 18" width="18" height="18">
              <path d="M5 13 13 5m0 0H6m7 0v7" />
            </svg>
          </a>
        </div>
        <ul class="hero-notes" aria-label="Download details">
          <li>
            <svg aria-hidden="true" viewBox="0 0 16 16"><path d="m3 8 3 3 7-7" /></svg>
            Free and open source
          </li>
          <li>
            <svg aria-hidden="true" viewBox="0 0 16 16"><path d="M8 1.8 13 4v3.4c0 3.1-2.1 5.8-5 6.8-2.9-1-5-3.7-5-6.8V4l5-2.2Z" /></svg>
            Signed and notarized
          </li>
          <li>{product.minimumMacOS}+</li>
        </ul>
      </div>

      <div class="hero-visual">
        <div class="shot-glow" aria-hidden="true"></div>
        <div class="product-shot">
          <div class="shot-topline" aria-hidden="true">
            <span></span><span></span><span></span>
            <p>Limit Lifeboat</p>
          </div>
          <Picture
            src={appScreenshot}
            formats={["avif", "webp"]}
            widths={[480, 720, 960, 1187]}
            sizes="(max-width: 760px) 88vw, (max-width: 1100px) 52vw, 560px"
            loading="eager"
            fetchpriority="high"
            alt="Limit Lifeboat menu-bar dashboard showing three Claude accounts and one Codex account with remaining usage meters."
          />
        </div>
        <div class="floating-pill floating-pill--usage" aria-hidden="true">
          <span class="pill-icon pill-icon--green">✓</span>
          <span><strong>All accounts visible</strong>At one glance</span>
        </div>
        <div class="floating-pill floating-pill--local" aria-hidden="true">
          <span class="pill-icon">⌁</span>
          <span><strong>Local-first</strong>Your data stays yours</span>
        </div>
      </div>
    </div>
    <div class="container proof-strip" aria-label="Product highlights">
      <div><strong>2 providers</strong><span>Claude + ChatGPT/Codex</span></div>
      <div><strong>One menu bar</strong><span>No dashboard juggling</span></div>
      <div><strong>Zero telemetry</strong><span>No product analytics</span></div>
      <div><strong>MIT licensed</strong><span>Open source on GitHub</span></div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <SectionHeading
        eyebrow="A calmer command center"
        title="Know what is available before you need it."
        copy="Limit Lifeboat turns scattered limits and logins into one quiet, dependable view—without becoming another dashboard you have to manage."
        align="center"
      />
      <div class="feature-grid">
        <article class="feature-card feature-card--wide">
          <div class="feature-copy">
            <span class="feature-icon feature-icon--violet">
              <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M4 18h16M6 15V9m6 6V5m6 10v-3" /></svg>
            </span>
            <p class="card-kicker">Every account, one view</p>
            <h3>Usage you can understand at a glance.</h3>
            <p>See session and weekly limits, the active CLI identity, and the age of each reading without opening provider dashboards.</p>
          </div>
          <div class="meter-demo" aria-hidden="true">
            <div class="demo-account"><span class="provider-glyph provider-glyph--claude">✦</span><strong>Claude</strong><span>3 accounts</span></div>
            <div class="demo-row">
              <span class="avatar avatar--violet">P</span>
              <div><strong>Personal</strong><small>Session</small></div>
              <div class="mini-meter"><span style="width: 66%"></span></div>
              <b>66%</b>
            </div>
            <div class="demo-row">
              <span class="avatar avatar--blue">W</span>
              <div><strong>Work</strong><small>Weekly</small></div>
              <div class="mini-meter"><span style="width: 28%"></span></div>
              <b>28%</b>
            </div>
          </div>
        </article>

        <article class="feature-card">
          <span class="feature-icon feature-icon--amber">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 4a6 6 0 0 0-6 6c0 7-3 7-3 7h18s-3 0-3-7a6 6 0 0 0-6-6Zm-2 16h4" /></svg>
          </span>
          <p class="card-kicker">Useful, optional warnings</p>
          <h3>Hear about limits before they interrupt you.</h3>
          <p>Get a notification when an account is nearly depleted—or likely ready to use again. You choose which alerts are enabled.</p>
          <div class="notice-demo" aria-hidden="true">
            <BrandMark size={38} />
            <span><strong>Claude Work is at 89%</strong>Consider switching before your next task.</span>
          </div>
        </article>

        <article class="feature-card">
          <span class="feature-icon feature-icon--cyan">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M8 7h11m0 0-3-3m3 3-3 3M16 17H5m0 0 3 3m-3-3 3-3" /></svg>
          </span>
          <p class="card-kicker">Safe CLI switching</p>
          <h3>Change accounts, not your configuration.</h3>
          <p>Switch Claude Code or Codex deliberately. Unrelated settings stay intact, the restored identity is verified, and failed changes roll back.</p>
          <div class="switch-demo" aria-hidden="true">
            <span><i class="avatar avatar--violet">P</i>Personal</span>
            <svg viewBox="0 0 32 20"><path d="M3 7h23m0 0-5-5m5 5-5 5M29 13H6m0 0 5 5m-5-5 5-5" /></svg>
            <span><i class="avatar avatar--blue">W</i>Work</span>
          </div>
        </article>

        <article class="feature-card feature-card--history">
          <span class="feature-icon feature-icon--green">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M4 19V9m5 10V5m5 14v-7m5 7V8" /></svg>
          </span>
          <p class="card-kicker">Usage history</p>
          <h3>See the rhythm, not just the number.</h3>
          <p>Local history helps reveal how quickly a limit is moving and whether the current pace is sustainable.</p>
          <div class="history-chart" aria-hidden="true">
            <svg viewBox="0 0 420 116" preserveAspectRatio="none">
              <defs>
                <linearGradient id="chart-fill" x1="0" y1="0" x2="0" y2="1">
                  <stop stop-color="#5d42c3" stop-opacity=".28" />
                  <stop offset="1" stop-color="#5d42c3" stop-opacity="0" />
                </linearGradient>
              </defs>
              <path class="chart-area" d="M0 99C45 96 48 84 88 83s60-25 104-20 49-23 95-15 61-30 133-38v106H0Z" />
              <path class="chart-line" d="M0 99C45 96 48 84 88 83s60-25 104-20 49-23 95-15 61-30 133-38" />
            </svg>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section setup-section" id="setup">
    <div class="container">
      <SectionHeading
        eyebrow="Up and running in minutes"
        title="Your accounts already know the way aboard."
        copy="There are no API keys to paste and no new account system to create. Limit Lifeboat works with the CLI logins you already use."
        align="center"
      />
      <ol class="steps">
        <li>
          <span class="step-number">01</span>
          <div class="step-icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M7 4h10v16H7zM10 17h4" /></svg></div>
          <h3>Install the app</h3>
          <p>Download the signed DMG or install the cask with Homebrew. Limit Lifeboat lives in the menu bar.</p>
        </li>
        <li>
          <span class="step-number">02</span>
          <div class="step-icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="m5 7 4 4-4 4m6 0h8" /></svg></div>
          <h3>Use your CLI logins</h3>
          <p>Log in with <code>claude</code> or <code>codex login</code>. On refresh, the active account registers itself.</p>
        </li>
        <li>
          <span class="step-number">03</span>
          <div class="step-icon"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3 4 7v5c0 5 3.4 8 8 9 4.6-1 8-4 8-9V7l-8-4Zm-3 9 2 2 4-5" /></svg></div>
          <h3>Stay in command</h3>
          <p>Watch usage, choose warnings, and switch a CLI only when you decide it is time.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="section security-section" id="security">
    <div class="container security-grid">
      <div class="security-visual" aria-hidden="true">
        <div class="security-ring security-ring--outer"></div>
        <div class="security-ring security-ring--middle"></div>
        <div class="shield-card">
          <BrandMark size={84} />
          <span><i></i>Protected by macOS</span>
        </div>
        <div class="security-tag security-tag--keychain">Keychain encrypted</div>
        <div class="security-tag security-tag--telemetry">Zero telemetry</div>
        <div class="security-tag security-tag--rollback">Verified restore</div>
      </div>
      <div class="security-copy">
        <p class="eyebrow">Local-first by design</p>
        <h2>Your credentials are cargo, not currency.</h2>
        <p class="section-copy">Limit Lifeboat is built to handle sensitive CLI authentication material with a small footprint and clear boundaries.</p>
        <ul class="check-list">
          <li><span>✓</span><div><strong>Credentials protected by macOS Keychain</strong><p>App-managed snapshots are encrypted by the system credential store.</p></div></li>
          <li><span>✓</span><div><strong>No analytics, ads, or product telemetry</strong><p>Your activity is not measured, profiled, or sold.</p></div></li>
          <li><span>✓</span><div><strong>Network access only where features need it</strong><p>Provider usage and identity services, GitHub update checks, and dashboards you explicitly open.</p></div></li>
          <li><span>✓</span><div><strong>Open source and inspectable</strong><p>The app is MIT licensed, with its implementation and release process on GitHub.</p></div></li>
        </ul>
        <a class="text-link" href="/privacy">Read the privacy details <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section install-section" id="download">
    <div class="container install-shell">
      <div class="install-orb" aria-hidden="true"></div>
      <div class="install-heading">
        <p class="eyebrow eyebrow--light">Ready when your next limit is not</p>
        <h2>Bring your accounts aboard.</h2>
        <p>Free, open source, and made for Apple Silicon Macs.</p>
      </div>
      <div class="install-grid">
        <article class="install-card install-card--primary">
          <span class="install-label">Recommended</span>
          <div class="install-card-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" /></svg>
          </div>
          <h3>Signed DMG</h3>
          <p>Download the latest signed and notarized release, then drag Limit Lifeboat to Applications.</p>
          <a class="button button--white" href={product.links.latestRelease}>Download for Mac <span aria-hidden="true">→</span></a>
        </article>
        <article class="install-card">
          <span class="install-label">For Homebrew users</span>
          <div class="install-card-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M5 5h14v14H5zM8 9l2.5 2.5L8 14m5 0h3" /></svg>
          </div>
          <h3>Homebrew Cask</h3>
          <p>Install from the personal tap. The cask uses the same published DMG as the GitHub release.</p>
          <pre class="command"><code>{product.homebrewCommand}</code></pre>
        </article>
      </div>
      <dl class="requirements">
        <div><dt>Requires</dt><dd>{product.minimumMacOS} or newer</dd></div>
        <div><dt>Hardware</dt><dd>{product.architecture}</dd></div>
        <div><dt>Current version</dt><dd>{product.version}</dd></div>
        <div><dt>Price</dt><dd>Free</dd></div>
      </dl>
    </div>
  </section>

  <section class="section faq-section">
    <div class="container faq-grid">
      <div class="faq-intro">
        <p class="eyebrow">Questions, answered</p>
        <h2>The practical details.</h2>
        <p class="section-copy">Still stuck? The support page has troubleshooting steps and the right place to report an issue.</p>
        <a class="button button--secondary" href="/support">Visit support</a>
      </div>
      <div class="faq-list">
        {faqs.map((item, index) => (
          <details open={index === 0}>
            <summary>{item.question}<span aria-hidden="true"></span></summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="closing-cta">
    <div class="container closing-cta-inner">
      <BrandMark size={64} />
      <div><h2>One menu bar. Every account.</h2><p>Make the next limit a decision, not a surprise.</p></div>
      <a class="button button--primary button--large" href={product.links.latestRelease}>Download for Mac</a>
    </div>
  </section>
</BaseLayout>
