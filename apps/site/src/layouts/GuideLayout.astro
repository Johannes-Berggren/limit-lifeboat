---
import { Picture } from "astro:assets";
import appScreenshot from "../assets/app-dashboard.png";
import BrandMark from "../components/BrandMark.astro";
import { product } from "../config";
import BaseLayout from "./BaseLayout.astro";

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  introduction: string;
  path: string;
  imageAlt: string;
  readingTime: string;
  faqs: readonly FAQ[];
}

const {
  title,
  description,
  eyebrow,
  introduction,
  path,
  imageAlt,
  readingTime,
  faqs,
} = Astro.props;

const datePublished = "2026-07-15";
const canonicalURL = new URL(path, product.siteUrl).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      headline: title,
      description,
      datePublished,
      dateModified: datePublished,
      mainEntityOfPage: canonicalURL,
      image: new URL("/og-card.png", product.siteUrl).toString(),
      author: {
        "@type": "Person",
        name: "Johannes Berggren",
        url: "https://github.com/Johannes-Berggren",
      },
      publisher: {
        "@type": "Organization",
        name: product.name,
        url: product.siteUrl,
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Limit Lifeboat",
          item: product.siteUrl,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: title,
          item: canonicalURL,
        },
      ],
    },
    {
      "@type": "FAQPage",
      mainEntity: faqs.map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  pageType="article"
  structuredData={structuredData}
>
  <section class="guide-hero">
    <div class="container guide-hero-grid">
      <div class="guide-hero-copy">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="/">Home</a><span aria-hidden="true">/</span><span>Guide</span>
        </nav>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="guide-introduction">{introduction}</p>
        <p class="guide-meta">
          Updated <time datetime={datePublished}>July 15, 2026</time>
          <span aria-hidden="true">·</span>
          {readingTime}
        </p>
      </div>
      <figure class="guide-figure">
        <Picture
          src={appScreenshot}
          formats={["avif", "webp"]}
          widths={[480, 720, 960]}
          sizes="(max-width: 900px) 92vw, 480px"
          loading="eager"
          alt={imageAlt}
        />
        <figcaption>Limit Lifeboat keeps account identity and usage visible in the Mac menu bar.</figcaption>
      </figure>
    </div>
  </section>

  <div class="container article-layout guide-layout">
    <aside class="article-nav" aria-label="On this page">
      <p>On this page</p>
      <slot name="nav" />
    </aside>
    <article class="prose guide-prose">
      <slot />

      <section id="questions">
        <h2>Questions and boundaries</h2>
        <div class="guide-faqs">
          {faqs.map((item) => (
            <div>
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </div>
          ))}
        </div>
      </section>
    </article>
  </div>

  <section class="guide-cta">
    <div class="container guide-cta-inner">
      <BrandMark size={56} />
      <div>
        <p class="eyebrow">Free and open source</p>
        <h2>Keep every authorized CLI account clear.</h2>
        <p>Monitor usage and switch deliberately without replacing the rest of your setup.</p>
      </div>
      <a class="button button--primary button--large" href={product.links.download}>Download for Mac</a>
    </div>
  </section>
</BaseLayout>
